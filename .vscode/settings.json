{
    // ============================================
    // Python Interpreter - Virtual Environment
    // ============================================
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,

    // Pylance - تحديد مسارات التحليل
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/.venv/Lib/site-packages"
    ],
    "python.analysis.typeCheckingMode": "off",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.ignore": [
        "${workspaceFolder}/.venv/**"
    ],

    // إيقاف تحذيرات الـ imports غير المحلولة
    "python.analysis.reportMissingImports": "none",
    "python.analysis.reportMissingModuleSource": "none",

    // ============================================
    // HTML / Jinja2 Templates
    // ============================================
    "html.validate.scripts": false,
    "html.validate.styles": false,
    "html.format.enable": false,

    "files.associations": {
        "*.html": "jinja-html"
    },

    "emmet.includeLanguages": {
        "jinja-html": "html"
    },

    // ============================================
    // Editor
    // ============================================
    "editor.formatOnSave": false,
    "editor.rulers": [120],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,

    // CSS
    "css.validate": false,
    "css.lint.unknownAtRules": "ignore",

    // Jinja HTML formatter
    "jinja-html.format.lineLength": 120,

    // إيقاف مشكلة trailing whitespace
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true
}
