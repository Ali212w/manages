Date: Tue, 12 May 2026 04:01:39 +0000
Subject: [PATCH] fix(dashboards): safe url_for + dashboard.index/analytics
 routes

- Add safe_url_for context processor that catches BuildError and
  returns '#' instead of crashing the whole page. This prevents 500
  errors when a shared partial (sidebar/header) references an
  endpoint that does not exist for the current blueprint set.
- Add dashboard.index that redirects to the role-appropriate dashboard
  (platform/company/role_dashboard/supplier/client/consultant).
- Add dashboard.analytics shortcut that maps to advanced_dashboard.

These were the root cause of every authenticated dashboard returning
500 (templates/partials/sidebar.html includes url_for('dashboard.index')
which never had a route).
---
 app/__init__.py                | 20 +++++++++++++++++
 app/routes/dashboard_routes.py | 40 +++++++++++++++++++++++++++++++---
 2 files changed, 57 insertions(+), 3 deletions(-)

diff --git a/app/__init__.py b/app/__init__.py
index 77c7f92..9ce7c0c 100644
--- a/app/__init__.py
+++ b/app/__init__.py
@@ -121,6 +121,26 @@ def create_app(config_name='default'):
                 return ''
 
         return dict(csrf_token=get_csrf_token)
+
+    @app.context_processor
+    def inject_safe_url_for():
+        """url_for آمن لا يكسر الصفحة إذا كان endpoint غير موجود.
+
+        يحل مشكلة قوالب مشتركة (مثل sidebar/header) تشير إلى endpoints
+        قد لا تكون مسجلة في كل مسار.
+        """
+        from flask import url_for as _flask_url_for
+        from werkzeug.routing.exceptions import BuildError
+
+        def safe_url_for(endpoint, **values):
+            try:
+                return _flask_url_for(endpoint, **values)
+            except BuildError:
+                return '#'
+            except Exception:
+                return '#'
+
+        return dict(url_for=safe_url_for, safe_url_for=safe_url_for)
